     uint32_t size_swa = GGML_PAD(std::min(size_base, hparams.n_swa*(unified ? n_seq_max : 1) + n_ubatch), 256);
 
+    // LLAMA_KV_SWA_OFFLOAD: when set, the SWA (sliding-window) KV cache is always
+    // placed in VRAM even when --no-kv-offload is active for the global KV cache.
+    // This implements a 2-tier KV layout:
+    //   - SWA cache  → VRAM (hot:  25 layers, window = n_swa tokens, fixed size ~100 MiB)
+    //   - Base cache → CPU  (cold: 5 layers,  full context, scales with ctx size)
+    // Usage: LLAMA_KV_SWA_OFFLOAD=1 llama-server --no-kv-offload -c 65536 ...
+    const bool offload_swa  = getenv("LLAMA_KV_SWA_OFFLOAD") != nullptr ? true  : offload;
+    const bool offload_base = getenv("LLAMA_KV_SWA_OFFLOAD") != nullptr ? false : offload;
+
+    // SUBVOCAL-PATCH-102-BEGIN: compact SWA cache with ISWA split
+    // When ISWA is active (offload_swa != offload_base), the full context is
+    // already in RAM via the base cache. Force the SWA cache to the sliding
+    // window size (n_swa tokens, ~100 MiB fixed) to save VRAM.
+    // Sliding-window models like Gemma 4 only need n_swa tokens by design.
+    if (offload_swa != offload_base) {
+        swa_full = false;
+    }
+    // SUBVOCAL-PATCH-102-END
+
     // when using full-size SWA cache, we set the SWA cache size to be equal to the base cache size
     if (swa_full) {
         LLAMA_LOG_WARN("%s: using full-size SWA cache (ref: %s)\n",
@@ -59,7 +79,8 @@ llama_kv_cache_iswa::llama_kv_cache_iswa(
