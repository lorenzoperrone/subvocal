+// SUBVOCAL-PATCH-101-BEGIN: set partial-forward layer limit at runtime.
+void llama_context::set_n_layer_limit(int32_t value) {
+    LLAMA_LOG_DEBUG("%s: value = %d\n", __func__, value);
+    if (value < 0) value = 0;
+    cparams.n_layer_limit = value;
+    // The graph builder reads cparams.n_layer_limit at every llama_decode call.
+    // No sched reserve flush needed: ggml_backend_sched_t detects topology changes
+    // via the graph hash and re-allocates buffers automatically.
+}
